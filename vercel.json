{
  "buildCommand": "bash scripts/inject-env.sh",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/shop",         "destination": "/pages/shop.html" },
    { "source": "/login",        "destination": "/pages/login.html" },
    { "source": "/history",      "destination": "/pages/history.html" },
    { "source": "/product",      "destination": "/pages/product.html" },
    { "source": "/checkout",     "destination": "/pages/checkout.html" },
    { "source": "/order-detail", "destination": "/pages/order-detail.html" },
    { "source": "/admin",        "destination": "/pages/admin/dashboard.html" },
    { "source": "/admin/(.*)",   "destination": "/pages/admin/$1.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",         "value": "DENY" },
        { "key": "Referrer-Policy",         "value": "strict-origin-when-cross-origin" },
        { "key": "X-XSS-Protection",        "value": "1; mode=block" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, stale-while-revalidate=86400" }
      ]
    }
  ]
}
